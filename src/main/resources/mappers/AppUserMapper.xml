<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.inventorymanager.mapper.AppUserMapper">

    <select id="findAll" resultType="com.example.inventorymanager.entity.AppUser">
        SELECT
            id,
            username,
            password,
            role,
            enabled
        FROM app_users
        ORDER BY id
    </select>

    <select id="findByUsername" resultType="com.example.inventorymanager.entity.AppUser">
        SELECT
            id,
            username,
            password,
            role,
            enabled
        FROM app_users
        WHERE username = #{username}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO app_users (
            username,
            password,
            role,
            enabled
        ) VALUES (
            #{username},
            #{password},
            #{role},
            #{enabled}
        )
    </insert>
</mapper>
